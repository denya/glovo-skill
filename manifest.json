{
  "manifest_version": "0.3",
  "name": "glovo",
  "display_name": "Glovo",
  "version": "0.2.1",
  "description": "Get personalized live Glovo suggestions, inspect products and history, and prepare baskets without checkout.",
  "author": {
    "name": "Denya"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/denya/glovo-skill.git"
  },
  "homepage": "https://github.com/denya/glovo-skill",
  "documentation": "https://github.com/denya/glovo-skill#readme",
  "support": "https://github.com/denya/glovo-skill/issues",
  "license": "MIT",
  "privacy_policies": [
    "https://glovoapp.com/en/legal/privacy",
    "https://policies.google.com/privacy"
  ],
  "keywords": ["glovo", "recommendations", "grocery", "food-delivery", "shopping", "basket", "orders", "mcp"],
  "server": {
    "type": "node",
    "entry_point": "dist/server.mjs",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/dist/server.mjs"],
      "env": {
        "GLOVO_SESSION_PATH": "${HOME}/.glovo/session.json",
        "GOOGLE_MAPS_API_KEY": "${user_config.google_maps_api_key}"
      }
    }
  },
  "user_config": {
    "google_maps_api_key": {
      "type": "string",
      "title": "Google Maps API key",
      "description": "Optional restricted Places API (New) key for shortlist quality evidence.",
      "sensitive": true,
      "required": false
    }
  },
  "tools_generated": true,
  "compatibility": {
    "platforms": ["darwin", "win32", "linux"],
    "runtimes": {
      "node": ">=18.0.0"
    }
  }
}
